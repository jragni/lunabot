# - Config file for the lunabot package
# It defines the following variables
#  lunabot_INCLUDE_DIRS - include directories for FooBar
#  lunabot_LIBRARIES    - libraries to link against
#  lunabot_EXECUTABLE   - the bar executable

set(lunabot_INCLUDE_DIRS "@CONF_INCLUDE_DIRS@")

# Our library dependencies (contains definitions for IMPORTED targets)
include("${lunabot_DIR}/export_lunabot.cmake")

# These are IMPORTED targets created by lunabotTargets.cmake


